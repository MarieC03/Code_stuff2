F90=/mnt/beegfs/IntelHDF5/hdf5-1.10.3/bin/h5pfc
CC=/mnt/beegfs/IntelHDF5/hdf5-1.10.3/bin/h5pcc
CXX=/mnt/beegfs/IntelHDF5_CXX/hdf5-1.10.3/bin/h5c++
FFLAGS = -c -g
CCFLAGS = -O0 -g -traceback
CXXFLAGS = -O0 -g -traceback
F90FLAGS = -xHost -O0 -FR -implicitnone -g -traceback -L/usr/lib/x86_64-linux-gnu/hdf5/serial -lstdc++
LINK= $(F90)  $(F90FLAGS)
