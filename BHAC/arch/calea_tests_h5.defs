F90=gfortran
CC=gcc 
CXX=g++
LIBS = -lgfortran
FFLAGS = -c 
F90FLAGS = -O0 -g3 -ffree-form -ffree-line-length-600 -fimplicit-none -I${HDF5_ROOT}/include -L${HDF5_ROOT}/lib -lstdc++ -lhdf5_fortran -lhdf5_cpp -lhdf5_hl_fortran -lhdf5_hl_cpp -lhdf5_hl -lhdf5 -lz -ldl -O0 -g -Wl,--copy-dt-needed-entries  
LINK = $(F90) $(F90FLAGS)
