############################################################################
#  Dependencies:
############################################################################
mod_limiter.o : ppm.o weno.o mp5.o
ppm.o : mod_imhd_intermediate.o
advance.o : mod_cfc.o mod_gw_br.o
amrini.o : mod_cfc_parameters.o
mod_physicaldata.o : mod_indices.o amrvacpar.o 
amr_fix_conserve.o : mod_fix_conserve.o
amr_gc_comm.o : mod_gc_comm.o
amr_ghostcells.o : mod_gc_comm.o
mod_metric.o               : mod_physicaldata.o
mod_post_process.o : mod_metric.o mod_imhd_intermediate.o mod_cfc_parameters.o
forest.o initialize_vars.o : mod_forest.o
amrvac.o initialize_vars.o : mod_connectivity.o mod_timing.o mod_variables.o mod_healpix_det.o
amrvacusr.o                : mod_oneblock.o mod_c2b_cart3d.o mod_post_process.o

# If ndim > 1, include multigrid functionality
#ifneq ($(ndim), 1)
FOBJECTS += mod_multigrid_coupling$F
OBJECTS += mod_multigrid_coupling.o

ifeq ($(ndim), 1)
mod_multigrid_coupling.o: m_octree_mg_1d.o
FOBJECTS += m_octree_mg_1d$F
OBJECTS += m_octree_mg_1d.o
endif
ifeq ($(ndim), 2)
mod_multigrid_coupling.o: m_octree_mg_2d.o
FOBJECTS += m_octree_mg_2d$F
OBJECTS += m_octree_mg_2d.o
endif

ifeq ($(ndim), 3)
mod_multigrid_coupling.o: m_octree_mg_3d.o
FOBJECTS += m_octree_mg_3d$F
OBJECTS += m_octree_mg_3d.o
endif

mod_multigrid_coupling.o: mod_forest.o
amrvac.o: mod_multigrid_coupling.o
#endif
