CarpetRegrid2::regrid_every		= 128
CarpetRegrid2::ensure_proper_nesting		= "yes"
CarpetRegrid2::freeze_unaligned_levels		= "yes"
CarpetRegrid2::freeze_unaligned_parent_levels	= "yes"
CarpetRegrid2::snap_to_coarse		= "yes"

