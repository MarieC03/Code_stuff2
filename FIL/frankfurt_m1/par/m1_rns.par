IllinoisGRMHD::c2p_Newton                       = yes
IllinoisGRMHD::c2p_residual_tol                 = 1.e-9
#IllinoisGRMHD::register_ADM_SandR               = no

IllinoisGRMHD::Symmetry = "equatorial"
 
